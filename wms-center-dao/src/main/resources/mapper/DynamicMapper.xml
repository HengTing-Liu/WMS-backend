<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
=============================================================================
安全说明：DynamicMapper.xml - SQL 注入防护层
=============================================================================

【重要】此 Mapper 所有 `${}` 占位符均为 SQL 标识符（表名/列名），MyBatis 要求必须
使用 `${}` 而非 `#{}`。标识符无法参数化，安全保障完全依赖上层 Service 层的校验。

【强制】调用前必须校验（由 Caller Service 层负责）：
  - tableCode → SqlInjectionValidator.validateTable(tableCode)
  - pkColumn  → SqlInjectionValidator.validateFieldFormat(pkColumn)
  - deleteColumn → SqlInjectionValidator.validateFieldFormat(deleteColumn)
  - field     → SqlInjectionValidator.validateField(field)
  - params keys → SqlInjectionValidator.validateFieldFormat(key)
  - data keys → SqlInjectionValidator.validateFieldFormat(key)

【受控来源】（可直接使用，无需校验）：
  - pkColumn: getPkColumn(tableCode) 返回 "id" 或 "user_id"
  - deleteColumn: getDeleteColumn(tableCode) 返回 sys_table_meta 配置值

【废弃方法】：
  - insert(String tableCode, String sql) - 已废弃，use insertParam
  - update(String tableCode, String sql) - 已废弃，use updateParam
  - executeQuery(...) - 未实现，调用会报错

=============================================================================
-->
<mapper namespace="com.abtk.product.dao.mapper.DynamicMapper">

    <!-- 动态查询列表（动态删除列 + 动态搜索参数） -->
    <!-- params 中的 key（字段名）必须在 Service 层通过 SAFE_FIELD_PATTERN 校验 -->
    <select id="selectList" resultType="java.util.Map">
        SELECT * FROM ${tableCode}
        WHERE ${deleteColumn} = 0
        <if test="params != null and params.size > 0">
            <foreach collection="params" item="value" index="key" open="AND " separator=" AND " close="">
                <if test="value != null and value != ''">
                    <choose>
                        <when test="queryModes != null and queryModes[key] != null and queryModes[key] == 'like'">
                            ${key} LIKE CONCAT('%', #{value}, '%')
                        </when>
                        <otherwise>
                            ${key} = #{value}
                        </otherwise>
                    </choose>
                </if>
            </foreach>
        </if>
        <if test="dataScope != null and dataScope != ''">
            AND (${dataScope})
        </if>
    </select>

    <!-- 查询所有（支持搜索参数和逻辑删除列） -->
    <select id="selectAll" resultType="java.util.Map">
        SELECT * FROM ${tableCode}
        WHERE ${deleteColumn} = 0
        <if test="params != null and params.size > 0">
            <foreach collection="params" item="value" index="key" open="AND " separator=" AND " close="">
                <if test="value != null and value != ''">
                    <choose>
                        <when test="queryModes != null and queryModes[key] != null and queryModes[key] == 'like'">
                            ${key} LIKE CONCAT('%', #{value}, '%')
                        </when>
                        <otherwise>
                            ${key} = #{value}
                        </otherwise>
                    </choose>
                </if>
            </foreach>
        </if>
        <if test="dataScope != null and dataScope != ''">
            AND (${dataScope})
        </if>
    </select>

    <!-- 根据ID查询 -->
    <select id="selectById" resultType="java.util.Map">
        SELECT * FROM ${tableCode} WHERE id = #{id}
    </select>

    <!-- 根据自定义主键列查询 -->
    <!-- pkColumn 来自 getPkColumn()，返回值受控 -->
    <select id="selectByIdWithColumn" resultType="java.util.Map">
        SELECT * FROM ${tableCode} WHERE ${pkColumn} = #{pkValue}
    </select>

    <!-- 动态插入（SQL字符串方式）【已废弃】 -->
    <!-- 高风险：直接拼接 SQL。禁止使用，请用 insertParam -->
    <insert id="insert">
        ${sql}
    </insert>

    <!-- 动态插入（参数化方式） -->
    <!-- columns 列表中的每个列名必须在 Service 层校验 -->
    <insert id="insertParam">
        INSERT INTO ${tableCode}
        <foreach collection="columns" item="col" open="(" separator="," close=")">
            ${col}
        </foreach>
        VALUES
        <foreach collection="values" item="val" open="(" separator="," close=")">
            #{val}
        </foreach>
    </insert>

    <!-- 动态更新（SQL字符串方式）【已废弃】 -->
    <!-- 高风险：直接拼接 SQL。禁止使用，请用 updateParam -->
    <update id="update">
        ${sql}
    </update>

    <!-- 动态更新（参数化方式） -->
    <!-- data Map 中的 key（字段名）必须在 Service 层校验 -->
    <update id="updateParam">
        UPDATE ${tableCode}
        <set>
            <foreach collection="data" index="key" item="val" separator=",">
                ${key} = #{val}
            </foreach>
        </set>
        WHERE ${pkColumn} = #{pkValue}
    </update>

    <!-- 逻辑删除（动态主键列 + 动态删除列） -->
    <!-- pkColumn 来自 getPkColumn()，deleteColumn 来自 getDeleteColumn()，均受控 -->
    <update id="logicDelete">
        UPDATE ${tableCode}
        SET ${deleteColumn} = '1'
        WHERE ${pkColumn} = #{pkValue}
    </update>

    <!-- 批量逻辑删除 -->
    <update id="batchLogicDelete">
        UPDATE ${tableCode}
        SET ${deleteColumn} = '1'
        WHERE ${pkColumn} IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 查询最后插入的ID -->
    <select id="selectLastInsertId" resultType="java.util.Map">
        SELECT LAST_INSERT_ID() as id
    </select>

    <!-- 查询表字段信息 -->
    <select id="selectTableColumns" resultType="java.util.Map">
        SELECT column_name, column_type, column_key, is_nullable, character_maximum_length, numeric_precision, numeric_scale
        FROM information_schema.columns
        WHERE table_schema = DATABASE() AND table_name = #{tableCode}
        ORDER BY ordinal_position
    </select>

    <!-- 检查唯一性 -->
    <!-- field 必须在 Service 层通过 validateField() 校验 -->
    <select id="checkUnique" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM ${tableCode}
        WHERE ${field} = #{value}
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

    <!--
    ========================================================================
    Lookup 虚拟列查询（WMS-LOWCODE-LOOKUP + WMS-LOWCODE-LOOKUP-DEDUP）
    ========================================================================
    安全：所有 ${} 占位符的值都来自已校验的 LookupColumn / SqlInjectionValidator 通过的字段。

    实现策略：<b>相关子查询 + LIMIT 1</b>（而非 LEFT JOIN），确保主表行数不会因关联
    表一对多匹配而膨胀。LookupColumn.getSqlExpression() 负责输出：
      (SELECT j.target_field FROM ref_table j WHERE j.match = m.local AND j.is_deleted = 0 LIMIT 1)
    或（多字段拼接）：
      (SELECT CONCAT_WS('❤', j.f1, j.f2) FROM ref_table j WHERE ... LIMIT 1)

    SQL 骨架：
      SELECT m.*, <子查询> AS alias_field, ...
      FROM ${tableCode} m
      WHERE m.${deleteColumn} = 0
        AND (主表参数)
        AND (<子查询> LIKE '%xx%')
        AND (dataScope)
    -->

    <sql id="lookupSelectColumns">
        m.*
        <if test="lookups != null and lookups.size > 0">
            <foreach collection="lookups" item="lk">
                , ${lk.sqlExpression} AS ${lk.aliasField}
            </foreach>
        </if>
    </sql>

    <!-- 保留空片段：历史已 include 的三个查询无需再改 -->
    <sql id="lookupJoinClauses">
    </sql>

    <sql id="lookupMainWhere">
        <if test="params != null and params.size > 0">
            <foreach collection="params" item="value" index="key" open="AND " separator=" AND " close="">
                <if test="value != null and value != ''">
                    <choose>
                        <when test="queryModes != null and queryModes[key] != null and queryModes[key] == 'like'">
                            m.${key} LIKE CONCAT('%', #{value}, '%')
                        </when>
                        <otherwise>
                            m.${key} = #{value}
                        </otherwise>
                    </choose>
                </if>
            </foreach>
        </if>
    </sql>

    <sql id="lookupVirtualWhere">
        <if test="virtualValues != null and virtualValues.size > 0">
            <foreach collection="virtualValues" item="value" index="key" open="AND " separator=" AND " close="">
                <if test="value != null and value != ''">
                    <choose>
                        <when test="virtualQueryModes != null and virtualQueryModes[key] != null and virtualQueryModes[key] == 'like'">
                            ${virtualExpressions[key]} LIKE CONCAT('%', #{value}, '%')
                        </when>
                        <otherwise>
                            ${virtualExpressions[key]} = #{value}
                        </otherwise>
                    </choose>
                </if>
            </foreach>
        </if>
    </sql>

    <select id="selectListJoined" resultType="java.util.Map">
        SELECT <include refid="lookupSelectColumns"/>
        FROM ${tableCode} m
        <include refid="lookupJoinClauses"/>
        WHERE m.${deleteColumn} = 0
        <include refid="lookupMainWhere"/>
        <include refid="lookupVirtualWhere"/>
        <if test="dataScope != null and dataScope != ''">
            AND (${dataScope})
        </if>
    </select>

    <select id="selectAllJoined" resultType="java.util.Map">
        SELECT <include refid="lookupSelectColumns"/>
        FROM ${tableCode} m
        <include refid="lookupJoinClauses"/>
        WHERE m.${deleteColumn} = 0
        <include refid="lookupMainWhere"/>
        <include refid="lookupVirtualWhere"/>
        <if test="dataScope != null and dataScope != ''">
            AND (${dataScope})
        </if>
    </select>

    <select id="selectByIdJoined" resultType="java.util.Map">
        SELECT <include refid="lookupSelectColumns"/>
        FROM ${tableCode} m
        <include refid="lookupJoinClauses"/>
        WHERE m.${pkColumn} = #{pkValue}
    </select>

</mapper>
