<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.abclonal.product.dao.mapper.ColumnMetaMapper">

    <resultMap id="ColumnMetaResult" type="com.abclonal.product.dao.entity.ColumnMeta">
        <id property="id" column="id"/>
        <result property="tableCode" column="table_code"/>
        <result property="field" column="field"/>
        <result property="title" column="title"/>
        <result property="dataType" column="data_type"/>
        <result property="formType" column="form_type"/>
        <result property="dictType" column="dict_type"/>
        <result property="showInList" column="show_in_list"/>
        <result property="showInForm" column="show_in_form"/>
        <result property="searchable" column="searchable"/>
        <result property="sortable" column="sortable"/>
        <result property="required" column="required"/>
        <result property="width" column="width"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="rulesJson" column="rules_json"/>
        <result property="status" column="status"/>
        <result property="componentProps" column="component_props"/>
        <result property="dataSource" column="data_source"/>
        <result property="apiUrl" column="api_url"/>
        <result property="labelField" column="label_field"/>
        <result property="valueField" column="value_field"/>
    </resultMap>

    <select id="selectByTableCode" resultMap="ColumnMetaResult">
        SELECT * FROM sys_column_meta
        WHERE table_code = #{tableCode} AND status = 1
        ORDER BY sort_order
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_column_meta (
            table_code, field, title, data_type, form_type, dict_type,
            show_in_list, show_in_form, searchable, sortable, required,
            width, sort_order, rules_json, status,
            component_props, data_source, api_url, label_field, value_field
        ) VALUES (
            #{tableCode}, #{field}, #{title}, #{dataType}, #{formType}, #{dictType},
            #{showInList}, #{showInForm}, #{searchable}, #{sortable}, #{required},
            #{width}, #{sortOrder}, #{rulesJson}, #{status},
            #{componentProps}, #{dataSource}, #{apiUrl}, #{labelField}, #{valueField}
        )
    </insert>

    <delete id="deleteById">
        DELETE FROM sys_column_meta WHERE id = #{id}
    </delete>

    <delete id="deleteByTableCode">
        DELETE FROM sys_column_meta WHERE table_code = #{tableCode}
    </delete>

</mapper>
