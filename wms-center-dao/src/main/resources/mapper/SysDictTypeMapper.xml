<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.abtk.product.dao.mapper.SysDictTypeMapper">

	<resultMap type="SysDictType" id="SysDictTypeResult">
		<id     property="id"          column="id"        />
		<result property="dictName"   column="dict_name" />
		<result property="dictType"   column="dict_type" />
		<result property="status"     column="status"    />
		<result property="languageType" column="language_type" />
		<result property="createBy"   column="create_by" />
		<result property="createTime" column="create_time" />
		<result property="updateBy"   column="update_by" />
		<result property="updateTime" column="update_time" />
		<result property="isDeleted"  column="is_deleted"  />
	</resultMap>
	
	<sql id="selectDictTypeVo">
        select id, dict_name, dict_type, status, language_type, create_by, create_time, update_by, update_time, remarks 
		from sys_dict_type
    </sql>

	<select id="selectDictTypeList" parameterType="SysDictType" resultMap="SysDictTypeResult">
	    <include refid="selectDictTypeVo"/>
		<where>
			is_deleted = '0'
		    <if test="dictName != null and dictName != ''">
				AND dict_name like concat('%', #{dictName}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
			<if test="dictType != null and dictType != ''">
				AND dict_type like concat('%', #{dictType}, '%')
			</if>
			<if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
				and date_format(create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
			</if>
			<if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
				and date_format(create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
			</if>
	    </where>
	</select>
	
	<select id="selectDictTypeAll" resultMap="SysDictTypeResult">
		<include refid="selectDictTypeVo"/>
		where is_deleted = '0'
	</select>
	
	<select id="selectDictTypeById" parameterType="Long" resultMap="SysDictTypeResult">
		<include refid="selectDictTypeVo"/>
		where id = #{id} and is_deleted = '0'
	</select>
	
	<select id="selectDictTypeByType" parameterType="String" resultMap="SysDictTypeResult">
		<include refid="selectDictTypeVo"/>
		where dict_type = #{dictType} and is_deleted = '0'
	</select>
	
	<select id="checkDictTypeUnique" parameterType="String" resultMap="SysDictTypeResult">
		<include refid="selectDictTypeVo"/>
		where dict_type = #{dictType} and is_deleted = '0' limit 1
	</select>
	
	<update id="deleteDictTypeById">
 		update sys_dict_type set is_deleted = '1', update_by = #{updateBy}, update_time = now() where id = #{id}
 	</update>
 	
 	<update id="deleteDictTypeByIds">
	update sys_dict_type set is_deleted = '1', update_by = #{updateBy}, update_time = now() where id in
		<foreach collection="ids" item="id" open="(" separator="," close=")">
			#{id}
        </foreach>
 	</update>

 	<update id="updateDictType" parameterType="SysDictType">
 		update sys_dict_type
 		<set>
 			<if test="dictName != null and dictName != ''">dict_name = #{dictName},</if>
 			<if test="dictType != null and dictType != ''">dict_type = #{dictType},</if>
 			<if test="status != null">status = #{status},</if>
 			<if test="languageType != null and languageType != ''">language_type = #{languageType},</if>
 			<if test="remarks != null">remarks = #{remarks},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			update_time = sysdate()
 		</set>
 		where id = #{id}
	</update>

	<update id="updateDictTypeStatus" parameterType="SysDictType">
		update sys_dict_type
		set status = #{status},
		    update_by = #{updateBy},
		    update_time = sysdate()
		where id = #{id}
	</update>
 	
 	<insert id="insertDictType" parameterType="SysDictType">
 		insert into sys_dict_type(
 			<if test="dictName != null and dictName != ''">dict_name,</if>
 			<if test="dictType != null and dictType != ''">dict_type,</if>
 			<if test="status != null">status,</if>
 			<if test="languageType != null and languageType != ''">language_type,</if>
 			<if test="remarks != null and remarks != ''">remarks,</if>
 			<if test="createBy != null and createBy != ''">create_by,</if>
 			create_time
 		)values(
 			<if test="dictName != null and dictName != ''">#{dictName},</if>
 			<if test="dictType != null and dictType != ''">#{dictType},</if>
 			<if test="status != null">#{status},</if>
 			<if test="languageType != null and languageType != ''">#{languageType},</if>
 			<if test="remarks != null and remarks != ''">#{remarks},</if>
 			<if test="createBy != null and createBy != ''">#{createBy},</if>
 			sysdate()
 		)
	</insert>
	
</mapper> 