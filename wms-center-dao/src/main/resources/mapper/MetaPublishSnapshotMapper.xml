<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.abtk.product.dao.mapper.MetaPublishSnapshotMapper">

    <resultMap id="MetaPublishSnapshotResult" type="com.abtk.product.dao.entity.MetaPublishSnapshot">
        <id property="id" column="id"/>
        <result property="publishId" column="publish_id"/>
        <result property="tableCode" column="table_code"/>
        <result property="snapshotType" column="snapshot_type"/>
        <result property="tableMetaJson" column="table_meta_json"/>
        <result property="columnMetaJson" column="column_meta_json"/>
        <result property="operationMetaJson" column="operation_meta_json"/>
        <result property="createdAt" column="created_at"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectByPublishId" resultMap="MetaPublishSnapshotResult">
        SELECT * FROM sys_meta_publish_snapshot
        WHERE publish_id = #{publishId}
        ORDER BY id ASC
    </select>

    <select id="selectLatestBeforeByTableCode" resultMap="MetaPublishSnapshotResult">
        SELECT * FROM sys_meta_publish_snapshot
        WHERE table_code = #{tableCode}
          AND snapshot_type = 'BEFORE'
        ORDER BY id DESC LIMIT 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_meta_publish_snapshot (
            publish_id, table_code, snapshot_type,
            table_meta_json, column_meta_json, operation_meta_json,
            create_by, create_time
        ) VALUES (
            #{publishId}, #{tableCode}, #{snapshotType},
            #{tableMetaJson}, #{columnMetaJson}, #{operationMetaJson},
            #{createBy}, NOW()
        )
    </insert>
</mapper>
