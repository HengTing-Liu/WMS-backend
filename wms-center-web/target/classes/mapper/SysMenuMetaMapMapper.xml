<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.abclonal.product.dao.mapper.SysMenuMetaMapMapper">

    <resultMap id="SysMenuMetaMapResult" type="com.abclonal.product.dao.entity.SysMenuMetaMap">
        <id property="menuId" column="menu_id"/>
        <result property="entityName" column="entity_name"/>
        <result property="listMode" column="list_mode"/>
        <result property="treeParentField" column="tree_parent_field"/>
        <result property="treeLabelField" column="tree_label_field"/>
        <result property="treeNodeType" column="tree_node_type"/>
        <result property="remarks" column="remarks"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectMenuMetaMapVo">
        SELECT menu_id, entity_name, list_mode, tree_parent_field, tree_label_field,
               tree_node_type, remarks, create_time, update_time
        FROM sys_menu_meta_map
    </sql>

    <select id="selectMenuMetaMapList" resultMap="SysMenuMetaMapResult">
        <include refid="selectMenuMetaMapVo"/>
        ORDER BY menu_id
    </select>

    <select id="selectMenuMetaMapById" parameterType="Long" resultMap="SysMenuMetaMapResult">
        <include refid="selectMenuMetaMapVo"/>
        WHERE menu_id = #{menuId}
    </select>

    <insert id="insertMenuMetaMap" parameterType="com.abclonal.product.dao.entity.SysMenuMetaMap">
        INSERT INTO sys_menu_meta_map (
            <if test="menuId != null">menu_id,</if>
            <if test="entityName != null">entity_name,</if>
            <if test="listMode != null">list_mode,</if>
            <if test="treeParentField != null">tree_parent_field,</if>
            <if test="treeLabelField != null">tree_label_field,</if>
            <if test="treeNodeType != null">tree_node_type,</if>
            <if test="remarks != null">remarks,</if>
            create_time
        ) VALUES (
            <if test="menuId != null">#{menuId},</if>
            <if test="entityName != null">#{entityName},</if>
            <if test="listMode != null">#{listMode},</if>
            <if test="treeParentField != null">#{treeParentField},</if>
            <if test="treeLabelField != null">#{treeLabelField},</if>
            <if test="treeNodeType != null">#{treeNodeType},</if>
            <if test="remarks != null">#{remarks},</if>
            sysdate()
        )
    </insert>

    <update id="updateMenuMetaMap" parameterType="com.abclonal.product.dao.entity.SysMenuMetaMap">
        UPDATE sys_menu_meta_map
        <set>
            <if test="entityName != null">entity_name = #{entityName},</if>
            <if test="listMode != null">list_mode = #{listMode},</if>
            <if test="treeParentField != null">tree_parent_field = #{treeParentField},</if>
            <if test="treeLabelField != null">tree_label_field = #{treeLabelField},</if>
            <if test="treeNodeType != null">tree_node_type = #{treeNodeType},</if>
            <if test="remarks != null">remarks = #{remarks},</if>
            update_time = sysdate()
        </set>
        WHERE menu_id = #{menuId}
    </update>

    <delete id="deleteMenuMetaMapById" parameterType="Long">
        DELETE FROM sys_menu_meta_map WHERE menu_id = #{menuId}
    </delete>

</mapper>
